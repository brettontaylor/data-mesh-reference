    "counterparty_src_to_bdm": {
      "version": "1.0.0",
      "surface": {
        "kind": "mapping",
        "from": "source:reference_feed",
        "to": "bdm:counterparty",
        "rules": [
          "counterparty_id<=cp_id:IDENTITY",
          "country_code<=country:LOOKUP",
          "credit_rating<=rating_agency+rating_raw:DERIVE",
          "internal_risk_score<=risk_model_out:IDENTITY",
          "legal_name<=name_raw:DERIVE",
          "lei<=lei_code:UPPER(TRIM(lei_code))"
        ]
      },
      "signature": "17b3d8dec8f598ed"
    },
    "trade_src_to_bdm": {
      "version": "1.1.0",
      "surface": {
        "kind": "mapping",
        "from": "source:trades_feed",
        "to": "bdm:trade",
        "rules": [
          "counterparty_id<=lei:LOOKUP",
          "currency_code<=ccy:IDENTITY",
          "instrument_id<=isin:LOOKUP",
          "notional<=quantity+price:quantity * price",
          "price<=price:IDENTITY",
          "quantity<=quantity:IDENTITY",
          "side<=buy_sell_flag:DERIVE",
          "source_trade_ref<=src_ref:IDENTITY",
          "trade_date<=trd_dt:DERIVE",
          "trade_id<=src_trade_id:IDENTITY",
          "trader_id<=trader_ref:IDENTITY"
        ]
      },
      "signature": "9c1f59aa3342313e"
    },
    "trade_dq": {
      "version": "2.0.0",
      "surface": {
        "kind": "dq",
        "target": "bdm:trade",
        "rules": [
          "currency_code:undefined:currency.currency_code:{}:undefined",
          "instrument_id:undefined:instrument.instrument_id:{}:undefined",
          "notional:undefined::{\"min\":0}:warn",
          "quantity:range::{\"min\":0}:warn",
          "side:undefined::{\"values\":[\"BUY\",\"SELL\"]}:undefined",
          "trade_id:undefined::{\"pattern\":\"^TRD-[0-9]+$\"}:warn",
          "trade_id:undefined::{}:undefined",
          "trade_id:undefined::{}:undefined",
          "undefined:undefined::{\"minRows\":5}:undefined",
          "undefined:undefined::{\"timestampField\":\"trade_date\",\"maxAgeHours\":24}:undefined"
        ]
      },
      "signature": "57414a6f29797c12"
    },
    "reg_trade_extract": {
      "version": "2.1.0",
      "surface": {
        "kind": "extract",
        "consumer": "Regulatory Reporting",
        "from": [
          "bdm:counterparty",
          "bdm:instrument",
          "bdm:trade"
        ],
        "columns": [
          "CounterpartyLEI<=counterparty.lei",
          "CurrencyCode<=trade.currency_code",
          "ISIN<=instrument.isin",
          "Notional<=trade.notional",
          "TradeDate<=trade.trade_date",
          "TradeId<=trade.trade_id"
        ],
        "grain": "one row per trade"
      },
      "signature": "25704311c061fa93"
    },
    "dim_instrument": {
      "version": "1.0.0",
      "surface": {
        "kind": "transformation",
        "target": "pdm:instrument_physical",
        "sources": [
          "A:instrument:",
          "B:currency:LEFT OUTER on A.currency_code = B.currency_code"
        ],
        "uses": [
          "currency_iso"
        ],
        "keyResolution": [],
        "assembly": "{}",
        "fields": [
          "AssetClass<=instrument.asset_class:DIRECT::",
          "CUSIP<=instrument.cusip:DIRECT::",
          "CurrencyDimID<=instrument.currency_code:REFMAP_LOOKUP:currency_iso:currency",
          "ISIN<=instrument.isin:DIRECT::",
          "InstrumentDimID<=:AUTO_SURROGATE::",
          "dtEnd<=:SCD2_END::",
          "dtStart<=:SCD2_START::"
        ]
      },
      "signature": "50feccc6d73aa921"
    },
    "dim_position": {
      "version": "1.0.0",
      "surface": {
        "kind": "transformation",
        "target": "pdm:position_physical",
        "sources": [
          "A:position:",
          "B:instrument:LEFT OUTER on A.instrument_id = B.instrument_id",
          "C:currency:LEFT OUTER on A.currency_code = C.currency_code"
        ],
        "uses": [
          "currency_iso",
          "instrument_key"
        ],
        "keyResolution": [
          "asset_class = BOND=>instrument.InstrumentDimID",
          "asset_class = EQUITY=>instrument.InstrumentDimID"
        ],
        "assembly": "{\"union\":[{\"branch\":\"position\",\"filter\":\"No Filter\",\"columns\":{\"status\":\"ACTIVE\"}},{\"branch\":\"position_closed\",\"filter\":\"as_of_date < current_date\",\"columns\":{\"status\":\"Default to CLOSED\"}}],\"subqueries\":[{\"alias\":\"latest_fx\",\"sql\":\"SELECT ccy, MAX(as_of_date) AS fx_date, rate FROM fx_rates GROUP BY ccy, rate\\n\"}]}",
        "fields": [
          "AsOfDate<=position.as_of_date:DIRECT::",
          "BookId<=position.book_id:DIRECT::",
          "CurrencyDimID<=position.currency_code:REFMAP_LOOKUP:currency_iso:currency",
          "DataSourceName<=:LITERAL::",
          "InstrumentDimID<=position.instrument_id:KEY_RESOLUTION:instrument_key:instrument",
          "MarketValue<=position.market_value:quantity * latest_fx.rate::",
          "PositionDimID<=:AUTO_SURROGATE::",
          "Quantity<=position.quantity:DIRECT::",
          "dtEnd<=:SCD2_END::",
          "dtStart<=:SCD2_START::"
        ]
      },
      "signature": "aa9ee3d2e2e69830"
    },
