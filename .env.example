# DEAL Control Tower — environment template. Copy to .env; set real values in your
# secret manager for production. NEVER commit real secrets. This is a public repo.

# --- server ---
PORT=4400
LOG_LEVEL=info

# --- models repo (GitOps system of record) ---
# Local filesystem (default: the bundled seed) or GitLab.
GIT_PROVIDER=local
# MODELS_DIR=/path/to/models-repo          # local provider only
# GIT_PROVIDER=gitlab
# GITLAB_HOST=https://gitlab.example.com
# GITLAB_PROJECT_ID=1234
# GITLAB_TOKEN=                            # bot token (repo scope) — from secret manager
# GITLAB_BRANCH=main

# --- projection store ---
# Unset → in-memory (dev/CI). Set → Postgres (production).
# DATABASE_URL=postgres://dct:dct@localhost:5432/dct

# --- identity / auth ---
# DEV_AUTH trusts x-dct-user/x-dct-roles headers — LOCAL/CI ONLY. Turn OFF in prod.
DEV_AUTH=true
# OIDC_ISSUER=https://login.microsoftonline.com/<tenant>/v2.0   # production SSO
DEV_ROLE=analyst

# --- Databricks (orchestration + Unity Catalog) ---
# DATABRICKS_HOST=https://adb-xxxx.azuredatabricks.net
# DATABRICKS_TOKEN=                        # workspace service-principal token

# --- redis (optional; job queue) ---
# REDIS_URL=redis://localhost:6379
