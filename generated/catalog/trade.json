{
  "dataProduct": "trade",
  "title": "Trade",
  "version": "0.1.0",
  "group": "transaction",
  "grain": "one row per executed trade",
  "owner": "trading-data",
  "source": {
    "id": "trades_feed",
    "kind": "csv",
    "cadenceDays": 1
  },
  "classificationSummary": {
    "internal": 5,
    "confidential": 3,
    "public": 1,
    "restricted": 1
  },
  "schema": [
    {
      "name": "trade_id",
      "type": "string",
      "classification": "internal",
      "primaryKey": true
    },
    {
      "name": "trade_date",
      "type": "date",
      "classification": "internal"
    },
    {
      "name": "instrument_id",
      "type": "string",
      "classification": "internal",
      "references": "instrument.instrument_id"
    },
    {
      "name": "counterparty_id",
      "type": "string",
      "classification": "internal",
      "references": "counterparty.counterparty_id"
    },
    {
      "name": "side",
      "type": "string",
      "classification": "internal"
    },
    {
      "name": "quantity",
      "type": "decimal(18,4)",
      "classification": "confidential",
      "mnpi": true
    },
    {
      "name": "price",
      "type": "decimal(18,6)",
      "classification": "confidential",
      "mnpi": true
    },
    {
      "name": "notional",
      "type": "decimal(18,2)",
      "classification": "confidential",
      "mnpi": true
    },
    {
      "name": "currency_code",
      "type": "string",
      "classification": "public",
      "references": "currency.currency_code"
    },
    {
      "name": "trader_id",
      "type": "string",
      "classification": "restricted",
      "pii": true
    }
  ],
  "lineage": {
    "bronze": "bronze_trade",
    "silver": "silver_trade",
    "gold": "GOLD.TRADE",
    "semantic": "cube:trade"
  },
  "metrics": [
    {
      "name": "notional_sum",
      "agg": "sum",
      "field": "notional",
      "description": "Total notional traded."
    },
    {
      "name": "trade_count",
      "agg": "count",
      "field": "trade_id",
      "description": "Number of trades."
    }
  ]
}