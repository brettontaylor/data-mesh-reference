{
  "version": "0.1.0",
  "model": "attribute-level access control (sensitivity tier + PII + MNPI)",
  "defaultRole": "public",
  "roles": [
    {
      "role": "public",
      "label": "Public",
      "description": "Anonymous / external. Public reference facts only.",
      "maxTier": "public",
      "pii": false,
      "mnpi": false
    },
    {
      "role": "analyst",
      "label": "Analyst",
      "description": "Internal analyst. Internal attributes; no PII, no MNPI.",
      "maxTier": "internal",
      "pii": false,
      "mnpi": false
    },
    {
      "role": "trader",
      "label": "Trader",
      "description": "Front office. Sees market-sensitive (MNPI) figures; no PII.",
      "maxTier": "confidential",
      "pii": false,
      "mnpi": true
    },
    {
      "role": "risk",
      "label": "Risk",
      "description": "Risk management. Counterparty PII + MNPI up to confidential.",
      "maxTier": "confidential",
      "pii": true,
      "mnpi": true
    },
    {
      "role": "compliance",
      "label": "Compliance",
      "description": "Oversight. Full visibility, including restricted attributes.",
      "maxTier": "restricted",
      "pii": true,
      "mnpi": true
    }
  ],
