# DCT AppKit app — local development env (copy to .env; never commit .env).

# ---- mode -------------------------------------------------------------
# local      = no Databricks needed: stub auth client, in-memory repo
# databricks = requires real workspace env (used when deployed)
APP_MODE=local

# ---- local server -----------------------------------------------------
DATABRICKS_APP_PORT=8000
# NODE_ENV is set by the pnpm scripts (dev=development, start=production)

# ---- optional: real Postgres locally (else in-memory repo) ------------
# DATABASE_URL=postgres://user:pass@localhost:5432/dct

# ---- auth (local dev) --------------------------------------------------
# Dev-auth accepts x-dct-user / x-dct-roles headers (the UI persona switcher
# sets them). Set DEV_AUTH=false to require real identity headers.
DEV_AUTH=true

# ---- deployed-only (injected by Databricks Apps platform) -------------
# DATABRICKS_HOST / DATABRICKS_CLIENT_ID / DATABRICKS_CLIENT_SECRET  (OAuth)
# PGHOST / PGDATABASE / PGPORT=5432 / PGSSLMODE=require              (Lakebase)
# LAKEBASE_ENDPOINT                                                  (app.yaml valueFrom)
# APP_DEFAULT_ROLES=modeler   # roles for platform-authenticated users
