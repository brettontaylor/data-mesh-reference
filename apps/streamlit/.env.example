# Streamlit parallel UI — local config (copy to .env; never commit .env).

# Base URL of the running @dct/appkit-app server (the shared governed API).
MMP_API_BASE=http://localhost:8137

# Dev-auth persona key: viewer | alice | bob | frank | carol | dana | pat
MMP_PERSONA=alice

# Documents intent for the switch (which UI is "active" in this environment).
# The flip is config-only — both UIs read the same MMP_API_BASE.
ACTIVE_UI=streamlit
